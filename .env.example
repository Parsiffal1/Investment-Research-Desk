IRD_OLLAMA_BASE_URL=http://localhost:11434/v1
IRD_OLLAMA_MODEL=qwen3:8b
IRD_DEFAULT_LLM_PROVIDER=auto

OKX_BASE_URL=https://www.okx.com
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1
JIN10_API_URL=
JIN10_API_KEY=

IRD_RUNS_DIR=runs
IRD_MARKET_DATA_VENDORS=okx,yahoo_finance,fmp
IRD_NEWS_DATA_VENDORS=jin10,finnhub,yahoo_finance
IRD_SENTIMENT_DATA_VENDORS=tavily,stocktwits,reddit
IRD_FUNDAMENTAL_DATA_VENDORS=fmp,finnhub

# Sentiment Analyst adapter runtime.
# main = use the report LLM only; hf-peft = use Qwen/Qwen3-8B + PEFT adapter for sentiment classification.
IRD_SENTIMENT_PROVIDER=main
IRD_SENTIMENT_BASE_MODEL=Qwen/Qwen3-8B
IRD_SENTIMENT_ADAPTER_PATH=
IRD_SENTIMENT_SCORE_BATCH_SIZE=4
